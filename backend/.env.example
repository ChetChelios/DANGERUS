# ============================================================
# Variables de entorno - copia este archivo como ".env" y
# ajusta los valores según tu instalación de PostgreSQL.
# ============================================================

# Puerto donde corre el servidor backend
PORT=4000

# Conexión a PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dgus_turnos
DB_USER=postgres
DB_PASSWORD=tu_contraseña_de_postgres

# Clave secreta para firmar los tokens JWT (cámbiala por cualquier texto largo y aleatorio)
JWT_SECRET=cambia_esto_por_un_texto_secreto_largo_y_unico_12345

# Tiempo de expiración del token de sesión
JWT_EXPIRES_IN=8h
